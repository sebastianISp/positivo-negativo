Algoritmo Positivo_Negativo
		
		Definir num Como Real
		
		Escribir "Ingresa un numero"
		Leer num
		
		Si num > 0 Entonces
			Escribir "El numero es positivo"
		Sino
			Si num < 0 Entonces
				Escribir "El numero es negativo"
			Sino
				Escribir "El numero es cero"
			FinSi
		FinSi
		
FinAlgoritmo
